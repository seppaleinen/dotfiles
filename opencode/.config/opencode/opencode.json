{
  "$schema": "https://opencode.ai/config.json",
  "mode": {},
  "permission": {
    "bash": {
      "*": "ask",
      "flux*": "ask",
      "helm*": "ask",
      "kubectl*": "ask",
      "ls*": "allow",
      "ll*": "allow",
      "la*": "allow",
      "cat*": "allow",
      "tail*": "allow",
      "head*": "allow",
      "grep*": "allow",
      "rg*": "allow",
      "find*": "allow",
      "echo*": "allow",
      "pwd*": "allow",
      "wc*": "allow",
      "sort*": "allow",
      "uniq*": "allow",
      "diff*": "allow",
      "which*": "allow",
      "type*": "allow",
      "env*": "allow",
      "printenv*": "allow",
      "date*": "allow",
      "uname*": "allow",
      "tree*": "allow",
      "jq*": "allow",
      "file*": "allow",
      "stat*": "allow",
      "du*": "allow",
      "df*": "allow",
      "ps*": "allow",
      "whoami*": "allow",
      "hostname*": "allow",
      "id*": "allow",
      "basename*": "allow",
      "dirname*": "allow",
      "realpath*": "allow",
      "readlink*": "allow",
      "cut*": "allow",
      "tr*": "allow",
      "awk*": "allow",
      "sed*": "allow",
      "xargs*": "allow",
      "git log*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git fetch*": "allow",
      "git stash list*": "allow",
      "flux check*": "allow",
      "flux diff*": "allow",
      "flux events*": "allow",
      "flux get*": "allow",
      "flux logs*": "allow",
      "flux reconcile*": "allow",
      "flux version*": "allow",
      "flux-local*": "allow",
      "source .venv/bin/activate": "allow",
      "pnpm*": "allow",
      "turbo*": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "write": "ask",
    "doom_loop": "ask"
  },
  "mcp": {
    "kubernetes": {
      "type": "remote",
      "url": "https://mcp.labb.site/k8s/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": ""
      }
    },
    "ijfw-memory": {
      "type": "local",
      "command": [
        "node",
        "/Users/daveri/.ijfw/mcp-server/src/server.js"
      ]
    }
  },
  "plugin": [
    "@cortexkit/opencode-magic-context@latest",
    "opencode-agent-tmux"
  ],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Proxy",
      "options": {
        "baseURL": "https://litellm.labb.site/v1",
        "apiKey": "sk-dummy-key-for-local"
      },
      "models": {
        "qwen/qwen3.6-35b-a3b": {
          "name": "qwen/qwen3.6-35b-a3b"
        }
      }
    },
    "oMLX": {
      "name": "oMLX",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "mlx-community/gpt-oss-20b-MXFP4-Q8": {
          "name": "mlx-community/gpt-oss-20b-MXFP4-Q8"
        },
        "unsloth/Qwen3.6-35B-A3B-UD-MLX-4bit": {
          "name": "unsloth/Qwen3.6-35B-A3B-UD-MLX-4bit"
        },
        "samwang0041/Qwen3.6-27B-MLX-4bit-MTP": {
          "name": "samwang0041/Qwen3.6-27B-MLX-4bit-MTP"
        },
        "samuelfaj/Qwen3.6-35B-A3B-4bit-MTPLX-Optimized-Speed": {
          "name": "samuelfaj/Qwen3.6-35B-A3B-4bit-MTPLX-Optimized-Speed"
        },
        "lmstudio-community/Qwen3.6-27B-MLX-4bit": {
          "name": "lmstudio-community/Qwen3.6-27B-MLX-4bit-dflash"
        },
        "gemma-4-26b-a4b-it-UD-MLX-4bit": {
          "name": "gemma-4-26b-a4b-it-UD-MLX-4bit"
        },
        "Devstral-Small-2-24B-Instruct-2512-4bit": {
          "name": "Devstral-Small-2-24B-Instruct-2512-4bit"
        },
        "Mistral-Small-3.2-24B-Instruct-2506-MLX-6bit": {
          "name": "Mistral-Small-3.2-24B-Instruct-2506-MLX-6bit"
        },
        "nightmedia/Qwen3.6-35B-A3B-MTP-Holo3-Qwopus-mxfp4-mlx": {
          "name": "nightmedia/Qwen3.6-35B-A3B-MTP-Holo3-Qwopus-mxfp4-mlx"
        }
      }
    },
    "local lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "qwen/qwen2.5-coder-14b": {
          "name": "qwen/qwen2.5-coder-14b"
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "qwen/qwen3.6-35b-a3b"
        },
        "google/gemma-4-26b-a4b-qat": {
          "name": "google/gemma-4-26b-a4b-qat"
        },
        "qwopus3.6-35b-a3b-v1-mtp": {
          "name": "qwopus3.6-35b-a3b-v1-mtp"
        },
        "qwopus3.6-35b-a3b-v1-apex-mtp": {
          "name": "qwopus3.6-35b-a3b-v1-apex-mtp"
        },
        "gemma-4-31b-it": {
          "name": "gemma-4-31b-it"
        },
        "glm-4.7-flash-reap-23b-a3b": {
          "name": "glm-4.7-flash-reap-23b-a3b"
        },
        "gemma-4-26b-a4b-it-qat": {
          "name": "unsloth/gemma-4-26b-a4b-it-qat"
        }
      }
    }
  },
  "lsp": true,
  "compaction": {
    "auto": false,
    "prune": false
  }
}