{
  "$schema": "https://opencode.ai/config.json",
  "mode": {},
  "permission": {
    "bash": {
      "*": "ask",
      "flux *": "ask",
      "helm *": "ask",
      "kubectl *": "ask",
      "ls *": "allow",
      "ll *": "allow",
      "la *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "echo *": "allow",
      "pwd *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "diff *": "allow",
      "which *": "allow",
      "type *": "allow",
      "env *": "allow",
      "printenv *": "allow",
      "date *": "allow",
      "uname *": "allow",
      "tree *": "allow",
      "jq *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "whoami *": "allow",
      "hostname *": "allow",
      "id *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "xargs *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "git fetch *": "allow",
      "git stash list *": "allow",
      "flux check *": "allow",
      "flux diff *": "allow",
      "flux events *": "allow",
      "flux get *": "allow",
      "flux logs *": "allow",
      "flux reconcile *": "allow",
      "flux version *": "allow",
      "flux-local *": "allow",
      "source .venv/bin/activate": "allow",
    },
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "write": "ask"
  },
  "mcp": {
    "kubernetes": {
      "type": "remote",
      "url": "https://mcp.labb.site/k8s/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Basic b3BlbmNvZGU6VFVPZ0kzUFNIeU9MMXluaXdWVm1DYnc1VHZlNW1rNUtJZk9MRmV2anUwaDkwQXNTdkQydzFzS21kVDlH"
      }
    }
  },
  "plugin": [
    "@cortexkit/opencode-magic-context@latest",
    "opencode-agent-tmux"
  ],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Proxy",
      "options": {
        "baseURL": "https://litellm.labb.site/v1",
        "apiKey": "sk-dummy-key-for-local"
      },
      "models": {
        "qwen/qwen3.6-35b-a3b": {
          "name": "qwen/qwen3.6-35b-a3b"
        }
      }
    },
    "oMLX": {
      "name": "oMLX",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "mlx-community/gpt-oss-20b-MXFP4-Q8": {
          "name": "mlx-community/gpt-oss-20b-MXFP4-Q8"
        },
        "unsloth/Qwen3.6-35B-A3B-UD-MLX-4bit": {
          "name": "unsloth/Qwen3.6-35B-A3B-UD-MLX-4bit"
        },
        "samwang0041/Qwen3.6-27B-MLX-4bit-MTP": {
          "name": "samwang0041/Qwen3.6-27B-MLX-4bit-MTP"
        },
        "samuelfaj/Qwen3.6-35B-A3B-4bit-MTPLX-Optimized-Speed": {
          "name": "samuelfaj/Qwen3.6-35B-A3B-4bit-MTPLX-Optimized-Speed"
        }
      }
    },
    "local lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "qwen/qwen2.5-coder-14b": {
          "name": "qwen/qwen2.5-coder-14b"
        },
        "mistralai/devstral-small-2-2512": {
          "name": "mistralai/devstral-small-2-2512"
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "qwen/qwen3.6-35b-a3b"
        }
      }
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  }
}
