{
  "$schema": "https://raw.githubusercontent.com/cortexkit/magic-context/master/assets/magic-context.schema.json",
  "historian": {
    "provider": "local lmstudio",
    "model": "local lmstudio/qwen2.5-coder-1.5b-instruct-mlx"
  },
  "dreamer": {
    "provider": "local lmstudio",
    "model": "local lmstudio/qwen2.5-coder-1.5b-instruct-mlx"
  },
  "sidekick": {
    "enabled": true,
    "maxHints": 3,              // Strict limit to prevent prompt bloating
    "similarityThreshold": 0.75 // Only inject highly relevant data
  },
  "memory": {
    "enabled": true,
    // Embeddings should ideally remain bound to a static, stable provider
    "provider": "local lmstudio",
    "embeddingModel": "local lmstudio/bge-m3-mlx" 
  }
}
